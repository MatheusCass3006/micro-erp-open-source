{
  "name": "microerp-desktop",
  "version": "1.0.0",
  "description": "MicroERP - Gestão Financeira Desktop",
  "main": "dist/main.js",
  "author": "MicroERP",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "tsc",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.microerp.desktop",
    "productName": "MicroERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "../financeiro-react/.next/standalone/**/*",
      "../financeiro-react/.next/static/**/*",
      "../financeiro-react/public/**/*"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "MicroERP.exe"
    },
    "publish": null,
    "asar": true,
    "asarUnpack": [
      "../financeiro-react/.next/static/**/*"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0"
  }
}