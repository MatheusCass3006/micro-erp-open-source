{
  "name": "microerp-server",
  "version": "1.0.0",
  "description": "MicroERP — servidor local offline",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build-exe": "npx pkg server.js --target node18-win-x64 --output microerp.exe"
  },
